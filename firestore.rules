rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActive() {
      return getUserData().active == true;
    }

    function isAdmin() {
      return isSignedIn() && isActive() && getUserData().role == 'admin';
    }

    function isStaff() {
      return isSignedIn() && isActive() && (getUserData().role == 'admin' || getUserData().role == 'staff');
    }

    function isViewer() {
      return isSignedIn() && isActive();
    }

    // Users collection
    // อ่าน profile ตัวเอง: ใช้ isSignedIn() เท่านั้น (ไม่เรียก get() เพิ่มเติม)
    // admin อ่าน profile คนอื่น: ต้องมี role=admin ใน document ของตัวเอง
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || request.auth.uid == uid;
      allow delete: if false;
    }

    // Drugs collection
    match /drugs/{drugId} {
      allow read: if isViewer();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // Unit types collection
    match /unitTypes/{unitTypeId} {
      allow read: if isViewer();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // Default sets collection
    match /defaultSets/{setId} {
      allow read: if isViewer();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // Default set items collection
    match /defaultSetItems/{itemId} {
      allow read: if isViewer();
      allow create, update, delete: if isAdmin();
    }

    // Field units collection
    match /fieldUnits/{fieldUnitId} {
      allow read: if isViewer();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if false;
    }

    // Field unit items collection
    match /fieldUnitItems/{itemId} {
      allow read: if isViewer();
      allow create, update: if isStaff();
      allow delete: if isStaff();
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if isViewer();
      allow write: if isAdmin();
    }

    // Activity logs collection
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isViewer();
      allow update, delete: if false;
    }
  }
}
